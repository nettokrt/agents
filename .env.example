# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (default: claude-opus-4-8)
PIPELINE_MODEL=claude-opus-4-8

# --- Atlassian (Jira) remote MCP ---
# Real Jira integration. The agents reach Jira through Atlassian's hosted MCP server
# via the Anthropic MCP connector. Supply an OAuth/access token for the MCP server.
ATLASSIAN_MCP_URL=https://mcp.atlassian.com/v1/sse
ATLASSIAN_MCP_TOKEN=
# Default Jira project key used when opening tickets (e.g. QA)
JIRA_PROJECT_KEY=

# --- GitLab remote MCP ---
# GitLab-hosted MCP server. Used to read repo context, commit generated specs,
# open merge requests, read pipeline/MR status, and create issues.
GITLAB_MCP_URL=https://gitlab.com/api/v4/mcp
GITLAB_TOKEN=
# Project the generated tests live in (numeric id or "group/project" path)
GITLAB_PROJECT=
